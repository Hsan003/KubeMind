# Environment Variables

# Application Settings
APP_NAME=KubeMind
APP_VERSION=0.1.0
DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite:///./incident_analyzer.db

# Logging
LOG_LEVEL=INFO

# Loki Configuration (Log Aggregation)
LOKI_URL=http://localhost:3100
LOKI_USERNAME=
LOKI_PASSWORD=

# Prometheus Configuration (Metrics)
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT_SECONDS=10.0
PROMETHEUS_DEFAULT_LOOKBACK_MINUTES=15
PROMETHEUS_DEFAULT_STEP=30s

# Kubernetes Configuration
KUBECONFIG_PATH=
NAMESPACE=default

# AI Model Configuration
MODEL_PROVIDER=openai
MODEL_API_KEY=
MODEL_NAME=gpt-4
